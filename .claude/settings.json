{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/scripts/hooks/pre-bash-block-destructive-git.js\""
          }
        ],
        "description": "Block destructive git commands (reset --hard, restore, checkout HEAD --, clean -f, push --force)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/scripts/hooks/pre-edit-block-large-delete.js\""
          }
        ],
        "description": "Block Edit/Write that delete >100 lines in a single call"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty false 2>&1 | head -20 || true"
          }
        ],
        "description": "Type-check after file edits to catch errors immediately"
      }
    ]
  }
}
