# cp .env.example .env.local 후 채울 것. 프로덕션은 Vercel에서 설정.

# Supabase — Dashboard > Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# 로컬: http://localhost:3000 / 프로덕션: 실제 도메인
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 32바이트 hex. 생성 (PowerShell): [guid]::NewGuid().ToString('N') + [guid]::NewGuid().ToString('N')
COOKIE_SECRET=replace-with-64-char-hex-string

# Google AdSense — 비워두면 광고 컴포넌트 + ads.txt 모두 비활성
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_DESKTOP_LEFT=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_DESKTOP_RIGHT=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_MOBILE_BOTTOM=1234567890
