# =============================================================================
# WhenMeets — Local Development Environment Variables
# =============================================================================
# 복사해서 사용: cp .env.local.example .env.local
# 프로덕션은 Vercel 대시보드에서 직접 설정

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://avwgiqkhkrdixwcopvod.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REDACTED_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REDACTED_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Site URL (프로덕션 필수)
# -----------------------------------------------------------------------------
# 로컬: http://localhost:3000
# 프로덕션: https://whenmeets.com (Vercel에서 설정)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cookie Secret (이벤트 비밀번호 토큰 서명용)
# -----------------------------------------------------------------------------
# openssl rand -hex 32 로 생성
COOKIE_SECRET=REDACTED_COOKIE_SECRET

# -----------------------------------------------------------------------------
# Google OAuth (Supabase에서 관리, 로컬 개발 시 supabase/config.toml 참조)
# -----------------------------------------------------------------------------
# Google Cloud Console > APIs & Services > Credentials 에서 생성
# Supabase 대시보드 > Auth > Providers > Google 에서도 설정 필요
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
