# =============================================================================
# WhenMeets — Local Development Environment Variables
# =============================================================================
# 사용법: cp .env.example .env.local 후 실제 값으로 채울 것
# 프로덕션은 Vercel 대시보드에서 직접 설정
# 절대 실제 secret을 이 파일에 적어 커밋하지 말 것 (이 파일은 git에 올라감)

# -----------------------------------------------------------------------------
# Supabase — 새 API 키 시스템 (publishable / secret)
# -----------------------------------------------------------------------------
# Supabase Dashboard > Project Settings > API Keys 에서 발급
# 기존 anon / service_role JWT 키는 deprecated, 새 프로젝트는 사용 불가

# 프로젝트 URL (예: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (구 anon key 대체) — 클라이언트 노출 OK, sb_publishable_ 접두사
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here

# Secret key (구 service_role key 대체) — 서버 전용, sb_secret_ 접두사, 절대 노출 금지
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# -----------------------------------------------------------------------------
# Site URL (프로덕션 필수)
# -----------------------------------------------------------------------------
# 로컬: http://localhost:3000
# 프로덕션: Vercel 배포 URL 또는 커스텀 도메인
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cookie Secret (이벤트 비밀번호 토큰 서명용)
# -----------------------------------------------------------------------------
# 32바이트(64 hex chars) 랜덤 값. 다음 중 환경에 맞는 것으로 생성:
#   Node.js  : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#   Git Bash : openssl rand -hex 32
#   macOS/Linux: openssl rand -hex 32
COOKIE_SECRET=replace-with-64-char-hex-string

# -----------------------------------------------------------------------------
# Google OAuth (Supabase에서 관리)
# -----------------------------------------------------------------------------
# 로컬 개발용은 supabase/config.toml의 [auth.external.google] 참조
# 프로덕션은 Supabase Dashboard > Auth > Providers > Google 에서 설정
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
